// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  librarian
  member
}

enum MembershipType {
  basic
  premium
  student
  standard
}

enum BorrowStatus {
  active
  overdue
  returned
}

enum FineStatus {
  unpaid
  paid
  waived
  pending
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  role         Role     @default(member)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  member         Member?
  librarian      Librarian?
  sessions        Session[]
  borrowRequests  BorrowRequest[]
  borrows         Borrow[]

  @@map("users")
}

model Librarian {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  name        String
  email       String   @unique
  phone       String?
  address     String?
  department  String?
  avatarColor String?  @map("avatar_color")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("librarians")
}

model Member {
  id             String         @id @default(cuid())
  userId         String         @unique @map("user_id")
  name           String
  email          String         @unique
  phone          String
  membershipNo   String         @unique @map("membership_no")
  address        String
  membershipType MembershipType @default(basic) @map("membership_type")
  joinedAt       DateTime       @default(now()) @map("joined_at")
  expiryDate     DateTime       @map("expiry_date")
  isActive       Boolean        @default(true) @map("is_active")
  activeBorrows  Int            @default(0) @map("active_borrows")
  unpaidFines    Decimal        @default(0) @map("unpaid_fines") @db.Decimal(10, 2)
  totalBorrows   Int            @default(0) @map("total_borrows")
  avatarColor    String?        @map("avatar_color")
  avatarUrl      String?        @map("avatar_url")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  borrowRecords   BorrowRecord[]
  fines           Fine[]
  recommendations Recommendation[]
  reviews         Review[]

  @@index([isActive])
  @@index([totalBorrows])
  @@map("members")
}



model Book {
  id              String   @id @default(cuid())
  title           String
  author          String
  isbn            String   @unique
  category        String
  year            Int
  description     String
  publisher       String?
  coverUrl        String?  @map("cover_url")
  totalCopies     Int      @map("total_copies")
  availableCopies Int      @map("available_copies")
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount     Int      @default(0) @map("review_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  borrowRecords   BorrowRecord[]
  recommendations Recommendation[]
  reviews         Review[]
  borrowRequests  BorrowRequest[]
  borrows         Borrow[]

  @@index([category])
  @@index([availableCopies])
  @@map("books")
}

model Review {
  id        String   @id @default(cuid())
  bookId    String   @map("book_id")
  memberId  String   @map("member_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([bookId, memberId])
  @@map("reviews")
}

model BorrowRecord {
  id           String       @id @default(cuid())
  memberId     String       @map("member_id")
  bookId       String       @map("book_id")
  issuedAt     DateTime     @default(now()) @map("issued_at")
  dueDate      DateTime     @map("due_date")
  returnedAt   DateTime?    @map("returned_at")
  status       BorrowStatus @default(active)
  extendedOnce Boolean      @default(false) @map("extended_once")
  fineAmount   Decimal?     @default(0) @map("fine_amount") @db.Decimal(10, 2)
  finePaid     Boolean      @default(false) @map("fine_paid")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  member Member @relation(fields: [memberId], references: [id])
  book   Book   @relation(fields: [bookId], references: [id])

  @@index([memberId])
  @@index([bookId])
  @@map("borrow_records")
}

model Fine {
  id          String     @id @default(cuid())
  borrowId    String     @unique @map("borrow_id")
  memberId    String     @map("member_id")
  overdueDays Int        @map("overdue_days")
  amount      Decimal    @db.Decimal(10, 2)
  isPaid      Boolean    @default(false) @map("is_paid")
  status      FineStatus @default(unpaid)
  createdAt   DateTime   @default(now()) @map("created_at")
  paidAt      DateTime?  @map("paid_at")

  borrow Borrow @relation(fields: [borrowId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId, status])
  @@map("fines")
}

model Recommendation {
  id        String   @id @default(cuid())
  bookId    String   @map("book_id")
  memberId  String   @map("member_id")
  score     Decimal  @db.Decimal(4, 3)
  strategy  String
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  book   Book   @relation(fields: [bookId], references: [id])
  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([memberId, strategy])
  @@index([score])
  @@map("recommendations")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Setting {
  key         String  @id
  value       String
  description String?

  @@map("settings")
}

enum OtpType {
  registration
  password_reset
}

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      OtpType
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, type])
  @@map("otps")
}

// ─── Borrow Code System ───────────────────────────────────────────────────────

enum BorrowRequestStatus {
  pending
  used
  expired
}

/// A short-lived request generated when a member wants to borrow a book.
/// The member shows the human-readable code to a librarian who confirms it.
model BorrowRequest {
  id        String              @id @default(cuid())
  code      String              @unique
  userId    String              @map("user_id")
  bookId    String              @map("book_id")
  status    BorrowRequestStatus @default(pending)
  createdAt DateTime            @default(now()) @map("created_at")
  expiresAt DateTime            @map("expires_at")

  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  book   Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  borrow Borrow?

  @@index([code])
  @@index([userId])
  @@map("borrow_requests")
}

/// A confirmed borrow record created after the librarian validates the code.
model Borrow {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  bookId          String    @map("book_id")
  borrowRequestId String?   @unique @map("borrow_request_id")
  borrowDate      DateTime  @default(now()) @map("borrow_date")
  dueDate         DateTime  @map("due_date")
  returnedAt      DateTime? @map("returned_at")
  returned        Boolean   @default(false)
  extendedOnce    Boolean   @default(false) @map("extended_once")
  createdAt       DateTime  @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  book          Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  borrowRequest BorrowRequest? @relation(fields: [borrowRequestId], references: [id])
  fine          Fine?

  @@index([userId])
  @@index([bookId])
  @@map("borrows")
}

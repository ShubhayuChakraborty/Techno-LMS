# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_64_char_random_secret_here
JWT_REFRESH_SECRET=another_64_char_random_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookies ───────────────────────────────────────────────────────────────────
COOKIE_SECRET=your_cookie_signing_secret_here

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Email domain restriction ──────────────────────────────────────────────────
# Only emails from this domain can register (default: technoindiaeducation.com)
ALLOWED_EMAIL_DOMAIN=technoindiaeducation.com

# ─── SMTP (for OTP emails) ─────────────────────────────────────────────────────
# Leave blank in development -- OTPs will be printed to the server console instead
# For Gmail: use an App Password (requires 2FA) at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-mlxf fehw omng rylg
EMAIL_FROM=noreply@technoindiaeducation.com

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Authorized JavaScript origins: http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
